# Supabase — copiá este archivo a .env.local y completá con tus valores.
# Project Settings -> API en el dashboard de Supabase.

# URL del proyecto (https://<ref>.supabase.co). Pública.
NEXT_PUBLIC_SUPABASE_URL=

# anon public key. Pública (segura en el browser: la respalda RLS).
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# service_role key. SECRETA. Solo en código server, NUNCA con prefijo NEXT_PUBLIC_.
# Bypassea RLS por completo. En Fase 0 no se usa (reservada para tareas admin/cron).
SUPABASE_SERVICE_ROLE_KEY=
