# Credenciales para los tests E2E (Playwright). Copiá este archivo a `.env.test`
# (gitignored) y completá la contraseña. Ya existe una cuenta de prueba
# `apitest@docsapp.test` con rol editor en el equipo TestingTest.
E2E_BASE_URL=http://localhost:3000
E2E_EMAIL=apitest@docsapp.test
E2E_PASSWORD=__completar__
